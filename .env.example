# Never commit real secrets. Put your own values in .env.
# The NVIDIA key pasted in chat should be rotated in your NVIDIA dashboard.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=mistralai/mistral-large-3-675b-instruct-2512
NVIDIA_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b

# NVIDIA NIM Extended Services (use same NVIDIA_API_KEY)
NVIDIA_IMAGE_ENABLED=false
NVIDIA_IMAGE_MODEL=black-forest-labs/flux-1-dev

# Hosted image-to-video. Requires account entitlement to the visual endpoint:
# https://ai.api.nvidia.com/v1/genai/stabilityai/stable-video-diffusion
# If entitlement is missing, ViralForge writes nvidia_provider_report.json and falls back locally.
NVIDIA_VIDEO_ENABLED=false
NVIDIA_VIDEO_BASE_URL=https://ai.api.nvidia.com/v1
NVIDIA_VIDEO_MODEL=stabilityai/stable-video-diffusion
NVIDIA_VIDEO_MAX_SCENES=2
NVIDIA_VIDEO_DURATION=8
NVIDIA_VIDEO_CFG_SCALE=1.8
NVIDIA_VIDEO_MOTION_BUCKET_ID=127

# NVIDIA Speech NIM TTS. This is usually a deployed NIM container/endpoint, not chat/completions.
# The documented HTTP endpoint is http://localhost:9000/v1/audio/synthesize.
NVIDIA_AUDIO_ENABLED=false
NVIDIA_AUDIO_BASE_URL=http://localhost:9000
NVIDIA_AUDIO_MODEL=magpie-tts-multilingual
NVIDIA_AUDIO_VOICE=Magpie-Multilingual.EN-US.Aria

# Google AI Studio video generation. Paste the real key only in .env.
GOOGLE_AI_API_KEY=
GOOGLE_VIDEO_ENABLED=false
GOOGLE_VIDEO_MODEL=veo-3.1-generate-preview
GOOGLE_VIDEO_MAX_SCENES=1
GOOGLE_VIDEO_DURATION_SECONDS=8
GOOGLE_VIDEO_ASPECT_RATIO=9:16
GOOGLE_VIDEO_RESOLUTION=720p
GOOGLE_VIDEO_MODE=text_to_video

# Pexels stock video/photo search. Paste the real key only in .env.
PEXELS_API_KEY=
PEXELS_ENABLED=false
PEXELS_VIDEO_ENABLED=true
PEXELS_MAX_CLIPS=6
PEXELS_ORIENTATION=portrait
PEXELS_SIZE=medium
PEXELS_LOCALE=en-US

# NVIDIA Stable Diffusion 3.5 specific key.
NVIDIA_SD35_API_KEY=

# Trend discovery
TREND_GEO=US
TREND_LANGUAGE=en
CHANNEL_NICHE=tech explainers,AI tools,science,creator economy

# Rendering
VIDEO_FORMAT=shorts
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_DURATION_SECONDS=58
VIDEO_FPS=30
VIDEO_BITRATE=15000k
AUDIO_SAMPLE_RATE=48000
AUDIO_TARGET_LUFS=-14
VOICE_ENGINE=edge
VOICE_NAME=en-US-GuyNeural
VOICE_RATE=+7%
VOICE_PITCH=-2Hz
MUSIC_ENABLED=true
MUSIC_VOLUME=0.18
SFX_ENABLED=true
PRESENTER_ENABLED=true
PRESENTER_STYLE=cinematic_host
PRESENTER_ASSET=assets/presenter-human.png

# Advanced cinematic rendering (Seedance2-quality without API)
ADVANCED_RENDERING=true
CINEMATIC_INTENSITY=0.85
PARTICLE_DENSITY=1.0

# Optional external AI video provider manifest. The local renderer still works when disabled.
SEEDANCE2_ENABLED=false
SEEDANCE2_API_KEY=
SEEDANCE2_BASE_URL=
SEEDANCE2_MODEL=seedance-2.0
SEEDANCE2_DURATION_SECONDS=8

# YouTube upload. Keep disabled until OAuth is set up and you are ready.
YOUTUBE_UPLOAD_ENABLED=false
YOUTUBE_CLIENT_SECRETS=credentials/client_secret.json
YOUTUBE_TOKEN_FILE=credentials/youtube_token.json
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=28
YOUTUBE_DEFAULT_LANGUAGE=en
YOUTUBE_SELF_DECLARED_MADE_FOR_KIDS=false
YOUTUBE_CONTAINS_SYNTHETIC_MEDIA=false

# Telegram control bot. Create a bot with @BotFather and paste the token here.
# Run /id first, then lock the bot to your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_OWNER_CHAT_IDS=
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_POLL_TIMEOUT=3
TELEGRAM_SEND_VIDEO_MAX_MB=45
SECURE_BOT_MAX_DAILY_RENDERS=6
SECURE_BOT_MAX_DAILY_UPLOADS=3
SECURE_BOT_REQUIRE_UPLOAD_APPROVAL=true
SECURE_BOT_FAST_RENDER=true
SECURE_BOT_INSTANCE_LOCK_PORT=48642
